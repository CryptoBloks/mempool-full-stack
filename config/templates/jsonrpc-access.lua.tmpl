-- JSON-RPC Access Control — Generated by mempool configurator
-- DO NOT EDIT — regenerate with: ./scripts/setup/generate-config.sh

local cjson = require "cjson"
local limit_req = require "resty.limit.req"

local api_keys_path = "{{API_KEYS_PATH}}"

local whitelisted_methods = {{WHITELISTED_METHODS}}

-- Rate limiter: shared dictionary "rpc_limit" must be defined in http {} block
-- 1 request/second burst capacity is per-key, actual rate set per-key below
local limiter, limiter_err = limit_req.new("rpc_limit", 1, 0)
if not limiter then
    ngx.log(ngx.ERR, "failed to create rate limiter: ", limiter_err)
end

-- JSON-RPC error response helper
local function jsonrpc_error(http_status, code, message, id)
    ngx.status = http_status
    ngx.header["Content-Type"] = "application/json"
    local resp = {
        jsonrpc = "2.0",
        error = {
            code = code,
            message = message
        },
        id = id or cjson.null
    }
    ngx.say(cjson.encode(resp))
    return ngx.exit(http_status)
end

local function load_api_keys()
    local f = io.open(api_keys_path, "r")
    if not f then
        ngx.log(ngx.ERR, "failed to open api keys file: ", api_keys_path)
        return nil
    end
    local content = f:read("*a")
    f:close()
    local ok, keys = pcall(cjson.decode, content)
    if not ok then
        ngx.log(ngx.ERR, "failed to parse api keys JSON")
        return nil
    end
    return keys
end

local function is_method_allowed(method)
    for _, m in ipairs(whitelisted_methods) do
        if m == method then
            return true
        end
    end
    return false
end

-- Extract API key: first try URL path /v1/{key}[/network], then X-API-Key header
local api_key = nil
local uri = ngx.var.uri
local path_key = uri:match("^/v1/([^/]+)")
if path_key and path_key ~= "" then
    api_key = path_key
end

if not api_key then
    api_key = ngx.req.get_headers()["X-API-Key"]
end

if not api_key then
    return jsonrpc_error(401, -32001, "Missing API key: provide via X-API-Key header or /v1/{key} path")
end

-- Validate API key
local api_keys = load_api_keys()
if not api_keys then
    return jsonrpc_error(500, -32603, "Internal error: unable to load API keys")
end

local key_entry = api_keys[api_key]
if not key_entry then
    return jsonrpc_error(403, -32002, "Invalid API key")
end

if key_entry.enabled == false then
    return jsonrpc_error(403, -32002, "API key is disabled")
end

-- Rate limiting (per-key)
if limiter then
    local per_key_rate = key_entry.rate_limit or 60
    -- lua-resty-limit-req uses requests/second; rate_limit is requests/minute
    local rate_per_sec = per_key_rate / 60
    -- Allow burst of up to 2x the per-second rate
    local burst = math.max(math.floor(rate_per_sec * 2), 1)

    -- Recreate limiter with per-key rate
    local key_limiter, key_err = limit_req.new("rpc_limit", rate_per_sec, burst)
    if key_limiter then
        local delay, err = key_limiter:incoming(api_key, true)
        if not delay then
            if err == "rejected" then
                return jsonrpc_error(429, -32005, "Rate limit exceeded: " .. per_key_rate .. " requests/minute")
            end
            ngx.log(ngx.ERR, "rate limiter error: ", err)
            -- Allow request through on limiter error
        end
        if delay and delay > 0 then
            ngx.sleep(delay)
        end
    else
        ngx.log(ngx.ERR, "failed to create per-key rate limiter: ", key_err)
    end
end

-- Read request body
ngx.req.read_body()
local body = ngx.req.get_body_data()
if not body then
    return jsonrpc_error(400, -32700, "Parse error: empty request body")
end

-- Parse JSON-RPC request
local ok, req = pcall(cjson.decode, body)
if not ok or not req.method then
    return jsonrpc_error(400, -32700, "Parse error: invalid JSON-RPC request")
end

local req_id = req.id

-- Validate method whitelist
if not is_method_allowed(req.method) then
    return jsonrpc_error(403, -32601, "Method not allowed: " .. req.method, req_id)
end
