# OpenResty Nginx Configuration — Generated by mempool configurator
# DO NOT EDIT — regenerate with: ./scripts/setup/generate-config.sh

worker_processes auto;
error_log /var/log/openresty/error.log warn;
pid /run/openresty.pid;

events {
    worker_connections 1024;
}

http {
    include       /usr/local/openresty/nginx/conf/mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout 65;

    # Shared memory zone for RPC rate limiting (10MB)
    lua_shared_dict rpc_limit 10m;

    # Upstream definitions (per-network)
{{UPSTREAM_BLOCKS}}

    server {
        listen 80;
{{SSL_CONFIG}}
        server_name {{SERVER_NAME}};

        # Mainnet API
{{MAINNET_API_LOCATIONS}}

        # Additional network APIs (signet, testnet)
{{NETWORK_API_LOCATIONS}}

        # Frontend
        location / {
            proxy_pass http://mempool-web;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

{{RPC_SERVER_BLOCK}}
}
